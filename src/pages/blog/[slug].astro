---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Navigation from '../../components/Navigation.astro';
import Footer from '../../components/Footer.astro';
import AdUnits from '../../components/AdUnits.astro';
import { getPostBySlug, getPosts, getPostsByCategory } from '../../config/posts';
import { siteConfig } from '../../config/siteConfig';
import { marked } from 'marked';

export async function getStaticPaths() {
  const posts = getPosts();
  return posts.map(post => ({
    params: { slug: post.slug },
    props: { post },
  }));
}

const { post } = Astro.props;
const contentHtml = marked(post.content);

const relatedPosts = getPostsByCategory(post.category)
  .filter(p => p.slug !== post.slug)
  .slice(0, 3);

const categoryColors: Record<string, string> = {
  'ai-chatbots': 'bg-blue-500',
  'ai-writing': 'bg-emerald-500',
  'ai-image': 'bg-purple-500',
  'ai-video': 'bg-pink-500',
  'ai-productivity': 'bg-amber-500',
  'ai-coding': 'bg-cyan-500',
};

const categoryColor = categoryColors[post.category] || 'bg-slate-500';
---

<BaseLayout
  title={post.title}
  description={post.description}
  image={post.image}
  type="article"
  publishedTime={post.pubDate.toISOString()}
  updatedTime={post.updatedDate?.toISOString()}
  author={post.author}
  section={post.category}
>
  <Navigation />

  <main>
    <article class="py-12 lg:py-16">
      <div class="mx-auto max-w-4xl px-4 sm:px-6 lg:px-8">
        <header class="mb-8">
          <div class="flex items-center gap-3 mb-4 flex-wrap">
            <a
              href={`/category/${post.category}`}
              class:list={['px-3 py-1 text-sm font-medium text-white rounded-full', categoryColor]}
            >
              {post.category.replace('-', ' ').replace(/\b\w/g, l => l.toUpperCase())}
            </a>
            {post.rating && (
              <div class="flex items-center gap-1 px-3 py-1 bg-amber-100 dark:bg-amber-900/30 text-amber-700 dark:text-amber-300 rounded-full">
                <svg class="w-4 h-4 text-amber-500 fill-amber-500" viewBox="0 0 20 20">
                  <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 9.162c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
                </svg>
                <span class="font-semibold">{post.rating.toFixed(1)}</span>
                <span class="text-amber-600/70">/ 5</span>
              </div>
            )}
          </div>

          <h1 class="text-3xl md:text-4xl lg:text-5xl font-bold text-slate-900 dark:text-white mb-4 leading-tight">
            {post.title}
          </h1>

          {post.verdict && (
            <p class="text-xl text-emerald-600 dark:text-emerald-400 font-medium mb-4">
              {post.verdict}
            </p>
          )}

          <p class="text-lg text-slate-600 dark:text-slate-400 mb-6">
            {post.description}
          </p>

          <div class="flex flex-wrap items-center gap-4 text-sm text-slate-500 dark:text-slate-400">
            <time datetime={post.pubDate.toISOString()}>
              {post.pubDate.toLocaleDateString('en-US', {
                year: 'numeric',
                month: 'long',
                day: 'numeric',
              })}
            </time>
            {post.updatedDate && (
              <>
                <span>•</span>
                <span>Updated {post.updatedDate.toLocaleDateString('en-US', {
                  year: 'numeric',
                  month: 'long',
                  day: 'numeric',
                })}</span>
              </>
            )}
            <span>•</span>
            <span>by {post.author}</span>
          </div>
        </header>

        {post.image && (
          <figure class="mb-10">
            <img
              src={post.image}
              alt={post.imageAlt || post.title}
              fetchpriority="high"
              class="w-full rounded-2xl shadow-lg"
            />
            {post.imageAlt && (
              <figcaption class="mt-3 text-sm text-slate-500 dark:text-slate-400 text-center">
                {post.imageAlt}
              </figcaption>
            )}
          </figure>
        )}

        <div class="grid md:grid-cols-4 gap-8 mb-10">
          <div class="md:col-span-1">
            <div class="bg-slate-50 dark:bg-slate-800 rounded-xl p-5 sticky top-24">
              <h3 class="font-semibold text-slate-900 dark:text-white mb-4">Quick Info</h3>
              
              {post.pricing && (
                <div class="mb-4">
                  <span class="text-xs text-slate-500 dark:text-slate-400 uppercase tracking-wider">Pricing</span>
                  <p class="font-medium text-slate-900 dark:text-white">{post.pricing}</p>
                </div>
              )}

              {post.bestFor && (
                <div class="mb-4">
                  <span class="text-xs text-slate-500 dark:text-slate-400 uppercase tracking-wider">Best For</span>
                  <p class="font-medium text-slate-900 dark:text-white">{post.bestFor}</p>
                </div>
              )}

              {post.features && post.features.length > 0 && (
                <div class="mb-4">
                  <span class="text-xs text-slate-500 dark:text-slate-400 uppercase tracking-wider">Key Features</span>
                  <ul class="mt-1 space-y-1">
                    {post.features.slice(0, 5).map(feature => (
                      <li class="flex items-start gap-1 text-sm text-slate-600 dark:text-slate-300">
                        <svg class="w-4 h-4 text-emerald-500 mt-0.5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                        </svg>
                        <span>{feature}</span>
                      </li>
                    ))}
                  </ul>
                </div>
              )}

              <a
                href="#"
                class="mt-4 w-full btn btn-primary justify-center"
              >
                Visit Website
                <svg class="w-4 h-4 ml-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
                </svg>
              </a>
            </div>
          </div>

          <div class="md:col-span-3">
            <div class="prose prose-slate dark:prose-invert max-w-none">
              <div set:html={contentHtml} />
            </div>

            {post.pros && post.pros.length > 0 && (
              <div class="mt-10 grid md:grid-cols-2 gap-6">
                <div class="bg-emerald-50 dark:bg-emerald-900/20 rounded-xl p-6">
                  <h3 class="font-bold text-emerald-700 dark:text-emerald-300 mb-4 flex items-center gap-2">
                    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" />
                    </svg>
                    Pros
                  </h3>
                  <ul class="space-y-2">
                    {post.pros.map(pro => (
                      <li class="flex items-start gap-2 text-slate-700 dark:text-slate-300">
                        <svg class="w-5 h-5 text-emerald-500 mt-0.5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                        </svg>
                        {pro}
                      </li>
                    ))}
                  </ul>
                </div>

                <div class="bg-red-50 dark:bg-red-900/20 rounded-xl p-6">
                  <h3 class="font-bold text-red-700 dark:text-red-300 mb-4 flex items-center gap-2">
                    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 14l2-2m0 0l2-2m-2 2l-2-2m2 2l2 2m7-2a9 9 0 11-18 0 9 9 0 0118 0z" />
                    </svg>
                    Cons
                  </h3>
                  <ul class="space-y-2">
                    {post.cons.map(con => (
                      <li class="flex items-start gap-2 text-slate-700 dark:text-slate-300">
                        <svg class="w-5 h-5 text-red-500 mt-0.5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
                        </svg>
                        {con}
                      </li>
                    ))}
                  </ul>
                </div>
              </div>
            )}

            {post.tags.length > 0 && (
              <div class="mt-10 pt-8 border-t border-slate-200 dark:border-slate-700">
                <h3 class="text-sm font-semibold text-slate-900 dark:text-white mb-4">Tags</h3>
                <div class="flex flex-wrap gap-2">
                  {post.tags.map(tag => (
                    <a
                      href={`/blog?tag=${tag}`}
                      class="px-3 py-1.5 text-sm bg-slate-100 dark:bg-slate-800 text-slate-600 dark:text-slate-300 rounded-full hover:bg-blue-100 dark:hover:bg-blue-900/20 hover:text-blue-600 dark:hover:text-blue-400 transition-colors"
                    >
                      #{tag}
                    </a>
                  ))}
                </div>
              </div>
            )}
          </div>
        </div>
      </div>
    </article>

    {relatedPosts.length > 0 && (
      <section class="py-12 lg:py-16 bg-slate-50 dark:bg-slate-800/50">
        <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
          <h2 class="text-2xl font-bold text-slate-900 dark:text-white mb-8">Related Reviews</h2>
          <div class="grid md:grid-cols-3 gap-6">
            {relatedPosts.map(related => (
              <a href={`/blog/${related.slug}`} class="group bg-white dark:bg-slate-800 rounded-xl border border-slate-200 dark:border-slate-700 overflow-hidden hover:shadow-lg transition-all">
                <div class="aspect-video bg-slate-100 dark:bg-slate-700 overflow-hidden">
                  {related.image ? (
                    <img
                      src={related.image}
                      alt={related.title}
                      class="w-full h-full object-cover group-hover:scale-105 transition-transform"
                      loading="lazy"
                    />
                  ) : (
                    <div class="w-full h-full flex items-center justify-center text-slate-400">
                      <svg class="w-12 h-12" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z" />
                      </svg>
                    </div>
                  )}
                </div>
                <div class="p-5">
                  <h3 class="font-semibold text-slate-900 dark:text-white mb-2 group-hover:text-blue-500 transition-colors">
                    {related.title}
                  </h3>
                  <p class="text-sm text-slate-500 dark:text-slate-400 line-clamp-2">
                    {related.description}
                  </p>
                </div>
              </a>
            ))}
          </div>
        </div>
      </section>
    )}
  </main>

  <Footer />
</BaseLayout>