---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Navigation from '../../components/Navigation.astro';
import Footer from '../../components/Footer.astro';
import { getPostBySlug, getPosts, getPostsByCategory } from '../../config/posts';
import { siteConfig } from '../../config/siteConfig';

import SectionHero from '../../components/sections/SectionHero.astro';
import SectionQuickFacts from '../../components/sections/SectionQuickFacts.astro';
import SectionIntro from '../../components/sections/SectionIntro.astro';
import SectionWhoIsFor from '../../components/sections/SectionWhoIsFor.astro';
import SectionFeatures from '../../components/sections/SectionFeatures.astro';
import SectionProsCons from '../../components/sections/SectionProsCons.astro';
import SectionComparison from '../../components/sections/SectionComparison.astro';
import SectionUseCases from '../../components/sections/SectionUseCases.astro';
import SectionExampleOutput from '../../components/sections/SectionExampleOutput.astro';
import SectionVerdict from '../../components/sections/SectionVerdict.astro';
import SectionFaq from '../../components/sections/SectionFaq.astro';

export async function getStaticPaths() {
  const posts = getPosts();
  return posts.map(post => ({
    params: { slug: post.slug },
    props: { post },
  }));
}

const { post } = Astro.props;

const relatedPosts = getPostsByCategory(post.category)
  .filter(p => p.slug !== post.slug)
  .slice(0, 3);

const categoryColors: Record<string, string> = {
  'ai-chatbots': 'bg-blue-500',
  'ai-writing': 'bg-emerald-500',
  'ai-image': 'bg-purple-500',
  'ai-video': 'bg-pink-500',
  'ai-productivity': 'bg-amber-500',
  'ai-coding': 'bg-cyan-500',
};

const categoryColor = categoryColors[post.category] || 'bg-slate-500';

const sectionComponents: Record<string, any> = {
  hero: SectionHero,
  quickFacts: SectionQuickFacts,
  intro: SectionIntro,
  whoIsFor: SectionWhoIsFor,
  whoIsNotFor: SectionWhoIsFor,
  features: SectionFeatures,
  prosCons: SectionProsCons,
  comparison: SectionComparison,
  useCases: SectionUseCases,
  exampleOutput: SectionExampleOutput,
  verdict: SectionVerdict,
  faq: SectionFaq,
};
---

<BaseLayout
  title={post.title}
  description={post.description}
  image={post.image}
  type="article"
  publishedTime={post.pubDate.toISOString()}
  updatedTime={post.updatedDate?.toISOString()}
  author={post.author}
  section={post.category}
>
  <Navigation />

  <main>
    {post.sections.map((section) => {
      const Component = sectionComponents[section.type];
      if (!Component) return null;

      if (section.type === 'hero') {
        return (
          <section>
            <Component
              heading={section.heading}
              subheading={section.subheading}
              highlight={section.highlight}
            />
          </section>
        );
      }

      if (section.type === 'quickFacts') {
        return <Component items={section.items} />;
      }

      if (section.type === 'intro') {
        return <Component content={section.content} />;
      }

      if (section.type === 'whoIsFor') {
        return <Component title={section.title} items={section.items} variant="for" />;
      }

      if (section.type === 'whoIsNotFor') {
        return <Component title={section.title} items={section.items} variant="notFor" />;
      }

      if (section.type === 'features') {
        return <Component title={section.title} items={section.items} />;
      }

      if (section.type === 'prosCons') {
        return <Component pros={section.pros} cons={section.cons} />;
      }

      if (section.type === 'comparison') {
        return <Component title={section.title} table={section.table} />;
      }

      if (section.type === 'useCases') {
        return <Component title={section.title} items={section.items} />;
      }

      if (section.type === 'exampleOutput') {
        return <Component title={section.title} content={section.content} />;
      }

      if (section.type === 'verdict') {
        return <Component title={section.title} content={section.content} cta={section.cta} ctaLink={section.ctaLink} />;
      }

      if (section.type === 'faq') {
        return <Component title={section.title} items={section.items} />;
      }

      return null;
    })}

    {relatedPosts.length > 0 && (
      <section class="py-12 lg:py-16 bg-slate-50 dark:bg-slate-800/50">
        <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
          <h2 class="text-2xl font-bold text-slate-900 dark:text-white mb-8">Related Reviews</h2>
          <div class="grid md:grid-cols-3 gap-6">
            {relatedPosts.map(related => (
              <a href={`/blog/${related.slug}`} class="group bg-white dark:bg-slate-800 rounded-xl border border-slate-200 dark:border-slate-700 overflow-hidden hover:shadow-lg transition-all">
                <div class="aspect-video bg-slate-100 dark:bg-slate-700 overflow-hidden">
                  {related.image ? (
                    <img
                      src={related.image}
                      alt={related.title}
                      class="w-full h-full object-cover group-hover:scale-105 transition-transform"
                      loading="lazy"
                    />
                  ) : (
                    <div class="w-full h-full flex items-center justify-center text-slate-400">
                      <svg class="w-12 h-12" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z" />
                      </svg>
                    </div>
                  )}
                </div>
                <div class="p-5">
                  <h3 class="font-semibold text-slate-900 dark:text-white mb-2 group-hover:text-blue-500 transition-colors">
                    {related.title}
                  </h3>
                  <p class="text-sm text-slate-500 dark:text-slate-400 line-clamp-2">
                    {related.description}
                  </p>
                </div>
              </a>
            ))}
          </div>
        </div>
      </section>
    )}
  </main>

  <Footer />
</BaseLayout>