---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Navigation from '../../components/Navigation.astro';
import Footer from '../../components/Footer.astro';
import ReviewCard from '../../components/ReviewCard.astro';
import { getPosts } from '../../config/posts';
import { siteConfig } from '../../config/siteConfig';

const allPosts = getPosts().sort((a, b) => b.pubDate.valueOf() - a.pubDate.valueOf());

const currentCategory = Astro.url.searchParams.get('category');
const currentSort = Astro.url.searchParams.get('sort') || 'latest';
const currentPricing = Astro.url.searchParams.get('pricing');

let filteredPosts = allPosts;

if (currentCategory) {
  filteredPosts = filteredPosts.filter(p => p.category === currentCategory);
}

if (currentPricing === 'free') {
  filteredPosts = filteredPosts.filter(p => p.pricing?.toLowerCase().includes('free'));
} else if (currentPricing === 'paid') {
  filteredPosts = filteredPosts.filter(p => !p.pricing?.toLowerCase().includes('free'));
}

if (currentSort === 'rating') {
  filteredPosts = filteredPosts.sort((a, b) => (b.rating || 0) - (a.rating || 0));
} else if (currentSort === 'popular') {
  filteredPosts = filteredPosts.sort((a, b) => b.pubDate.valueOf() - a.pubDate.valueOf());
}

const page = Astro.url.searchParams.get('page') ? parseInt(Astro.url.searchParams.get('page')!) : 1;
const postsPerPage = 9;
const totalPages = Math.ceil(filteredPosts.length / postsPerPage);
const paginatedPosts = filteredPosts.slice((page - 1) * postsPerPage, page * postsPerPage);
---

<BaseLayout
  title="All Reviews"
  description={`Browse all ${siteConfig.name} reviews and comparisons. Find the best AI tools for your needs.`}
>
  <Navigation />

  <main>
    <section class="py-12 lg:py-16">
      <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
        <div class="text-center mb-12">
          <h1 class="text-4xl md:text-5xl font-bold text-slate-900 dark:text-white mb-4">
            AI Tool Reviews
          </h1>
          <p class="text-lg text-slate-600 dark:text-slate-400 max-w-2xl mx-auto">
            In-depth reviews and comparisons to help you find the perfect AI tool for your needs.
          </p>
        </div>

        <div class="bg-white dark:bg-slate-800 rounded-xl border border-slate-200 dark:border-slate-700 p-4 mb-8">
          <div class="flex flex-col lg:flex-row gap-4">
            <div class="flex-1">
              <div class="relative">
                <svg class="absolute left-3 top-1/2 -translate-y-1/2 w-5 h-5 text-slate-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
                </svg>
                <input
                  type="search"
                  placeholder="Search AI tools..."
                  class="w-full pl-10 pr-4 py-2.5 bg-slate-50 dark:bg-slate-900 border border-slate-200 dark:border-slate-700 rounded-lg focus:outline-none focus:ring-2 focus:ring-blue-500/50"
                />
              </div>
            </div>
            
            <div class="flex flex-wrap gap-3">
              <select class="px-4 py-2.5 bg-slate-50 dark:bg-slate-900 border border-slate-200 dark:border-slate-700 rounded-lg focus:outline-none focus:ring-2 focus:ring-blue-500/50">
                <option value="">All Categories</option>
                {siteConfig.categories.map(cat => (
                  <option value={cat.slug} selected={currentCategory === cat.slug}>
                    {cat.name}
                  </option>
                ))}
              </select>

              <select class="px-4 py-2.5 bg-slate-50 dark:bg-slate-900 border border-slate-200 dark:border-slate-700 rounded-lg focus:outline-none focus:ring-2 focus:ring-blue-500/50">
                <option value="latest" selected={currentSort === 'latest'}>Latest</option>
                <option value="rating" selected={currentSort === 'rating'}>Highest Rated</option>
                <option value="popular" selected={currentSort === 'popular'}>Most Popular</option>
              </select>

              <select class="px-4 py-2.5 bg-slate-50 dark:bg-slate-900 border border-slate-200 dark:border-slate-700 rounded-lg focus:outline-none focus:ring-2 focus:ring-blue-500/50">
                <option value="">All Pricing</option>
                <option value="free" selected={currentPricing === 'free'}>Free</option>
                <option value="paid" selected={currentPricing === 'paid'}>Paid</option>
              </select>

              <a href="/compare" class="inline-flex items-center gap-2 px-4 py-2.5 bg-blue-500 text-white rounded-lg font-medium hover:bg-blue-600 transition-colors">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z" />
                </svg>
                Compare
              </a>
            </div>
          </div>
        </div>

        <div class="flex items-center gap-2 mb-6 flex-wrap">
          <span class="text-sm text-slate-500 dark:text-slate-400">Showing</span>
          <span class="px-2 py-1 bg-blue-100 dark:bg-blue-900/30 text-blue-600 dark:text-blue-400 text-sm font-medium rounded">
            {filteredPosts.length}
          </span>
          <span class="text-sm text-slate-500 dark:text-slate-400">reviews</span>
          
          {currentCategory && (
            <a href="/blog" class="ml-2 inline-flex items-center gap-1 px-2 py-1 text-xs bg-slate-100 dark:bg-slate-800 text-slate-600 dark:text-slate-300 rounded hover:bg-slate-200 dark:hover:bg-slate-700">
              {siteConfig.categories.find(c => c.slug === currentCategory)?.name}
              <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
              </svg>
            </a>
          )}
        </div>

        {paginatedPosts.length > 0 ? (
          <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6">
            {paginatedPosts.map(post => (
              <ReviewCard
                slug={post.slug}
                title={post.title}
                description={post.description}
                image={post.image}
                imageAlt={post.imageAlt}
                category={post.category}
                rating={post.rating}
                price={post.pricing}
                bestFor={post.bestFor}
                pubDate={post.pubDate}
              />
            ))}
          </div>
        ) : (
          <div class="text-center py-16">
            <svg class="w-16 h-16 mx-auto text-slate-300 dark:text-slate-600 mb-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9.172 16.172a4 4 0 015.656 0M9 10h.01M15 10h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
            </svg>
            <h3 class="text-xl font-semibold text-slate-900 dark:text-white mb-2">No reviews found</h3>
            <p class="text-slate-500 dark:text-slate-400 mb-6">Try adjusting your filters or search for something else.</p>
            <a href="/blog" class="inline-flex items-center gap-2 px-5 py-2.5 bg-blue-500 text-white rounded-lg font-medium hover:bg-blue-600 transition-colors">
              Clear Filters
            </a>
          </div>
        )}

        {totalPages > 1 && (
          <div class="flex justify-center gap-2 mt-12">
            {page > 1 && (
              <a
                href={`/blog?page=${page - 1}${currentCategory ? `&category=${currentCategory}` : ''}${currentSort !== 'latest' ? `&sort=${currentSort}` : ''}`}
                class="px-4 py-2.5 bg-slate-100 dark:bg-slate-800 text-slate-700 dark:text-slate-300 rounded-lg hover:bg-slate-200 dark:hover:bg-slate-700 font-medium transition-colors"
              >
                ← Previous
              </a>
            )}
            
            <div class="flex items-center gap-2">
              {Array.from({ length: totalPages }, (_, i) => i + 1).map(pageNum => (
                <a
                  href={`/blog?page=${pageNum}${currentCategory ? `&category=${currentCategory}` : ''}${currentSort !== 'latest' ? `&sort=${currentSort}` : ''}`}
                  class:list={[
                    'w-10 h-10 flex items-center justify-center rounded-lg font-medium transition-colors',
                    pageNum === page 
                      ? 'bg-blue-500 text-white' 
                      : 'bg-slate-100 dark:bg-slate-800 text-slate-700 dark:text-slate-300 hover:bg-slate-200 dark:hover:bg-slate-700'
                  ]}
                >
                  {pageNum}
                </a>
              ))}
            </div>

            {page < totalPages && (
              <a
                href={`/blog?page=${page + 1}${currentCategory ? `&category=${currentCategory}` : ''}${currentSort !== 'latest' ? `&sort=${currentSort}` : ''}`}
                class="px-4 py-2.5 bg-slate-100 dark:bg-slate-800 text-slate-700 dark:text-slate-300 rounded-lg hover:bg-slate-200 dark:hover:bg-slate-700 font-medium transition-colors"
              >
                Next →
              </a>
            )}
          </div>
        )}
      </div>
    </section>
  </main>

  <Footer />
</BaseLayout>