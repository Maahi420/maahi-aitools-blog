---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Navigation from '../../components/Navigation.astro';
import Footer from '../../components/Footer.astro';
import { getPosts } from '../../config/posts';
import { siteConfig } from '../../config/siteConfig';

const allPosts = getPosts().sort((a, b) => b.pubDate.valueOf() - a.pubDate.valueOf());

const page = Astro.url.searchParams.get('page') ? parseInt(Astro.url.searchParams.get('page')!) : 1;
const postsPerPage = 12;
const totalPages = Math.ceil(allPosts.length / postsPerPage);
const paginatedPosts = allPosts.slice((page - 1) * postsPerPage, page * postsPerPage);
---

<BaseLayout
  title="All Reviews"
  description={`Browse all ${siteConfig.name} reviews and comparisons. Find the best AI tools for your needs.`}
>
  <Navigation />

  <main class="mx-auto max-w-6xl px-4 py-12">
    <header class="mb-12">
      <h1 class="text-3xl md:text-4xl font-bold mb-4">All Reviews</h1>
      <p class="text-lg text-slate-600 dark:text-slate-400">
        Browse all our AI tool reviews and comparisons.
      </p>
    </header>

    <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8">
      {paginatedPosts.map(post => (
        <a
          href={`/blog/${post.slug}`}
          class="group block bg-white dark:bg-slate-800 rounded-xl border border-slate-200 dark:border-slate-700 overflow-hidden hover:shadow-lg transition-shadow"
        >
          <div class="aspect-video bg-slate-100 dark:bg-slate-700 overflow-hidden">
            {post.image ? (
              <img
                src={post.image}
                alt={post.title}
                class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300"
                loading="lazy"
              />
            ) : (
              <div class="w-full h-full flex items-center justify-center text-slate-400">
                <svg class="w-12 h-12" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z" />
                </svg>
              </div>
            )}
          </div>
          <div class="p-5">
            <span class="inline-block px-2 py-1 text-xs font-medium text-blue-500 bg-blue-50 dark:bg-blue-900/20 rounded-full mb-3">
              {post.category.replace('-', ' ').replace(/\b\w/g, l => l.toUpperCase())}
            </span>
            <h3 class="text-lg font-semibold mb-2 group-hover:text-blue-500 transition-colors">
              {post.title}
            </h3>
            <p class="text-slate-600 dark:text-slate-400 text-sm line-clamp-2">
              {post.description}
            </p>
            <time class="block mt-3 text-sm text-slate-500">
              {post.pubDate.toLocaleDateString('en-US', {
                month: 'short',
                day: 'numeric',
                year: 'numeric',
              })}
            </time>
          </div>
        </a>
      ))}
    </div>

    {totalPages > 1 && (
      <div class="flex justify-center gap-2 mt-12">
        {page > 1 && (
          <a
            href={`/blog?page=${page - 1}`}
            class="px-4 py-2 bg-slate-100 dark:bg-slate-800 rounded-lg hover:bg-slate-200 dark:hover:bg-slate-700"
          >
            Previous
          </a>
        )}
        <span class="px-4 py-2">
          Page {page} of {totalPages}
        </span>
        {page < totalPages && (
          <a
            href={`/blog?page=${page + 1}`}
            class="px-4 py-2 bg-slate-100 dark:bg-slate-800 rounded-lg hover:bg-slate-200 dark:hover:bg-slate-700"
          >
            Next
          </a>
        )}
      </div>
    )}
  </main>

  <Footer />
</BaseLayout>