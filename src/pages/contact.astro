---
import BaseLayout from '../layouts/BaseLayout.astro';
import Navigation from '../components/Navigation.astro';
import Footer from '../components/Footer.astro';
import { siteConfig } from '../config/siteConfig';
---

<BaseLayout
  title="Contact"
  description="Get in touch with AI Tools Review. We'd love to hear from you."
>
  <Navigation />

  <main class="mx-auto max-w-3xl px-4 py-12">
    <h1 class="text-3xl md:text-4xl font-bold mb-8">Contact Us</h1>

    <div class="prose prose-slate dark:prose-invert max-w-none mb-12">
      <p>
        Have a question, suggestion, or want to suggest an AI tool for review?
        We'd love to hear from you.
      </p>
    </div>

    <form class="space-y-6">
      <div>
        <label for="name" class="block text-sm font-medium mb-2">Name</label>
        <input
          type="text"
          id="name"
          name="name"
          required
          class="w-full px-4 py-3 bg-white dark:bg-slate-800 border border-slate-200 dark:border-slate-700 rounded-lg focus:outline-none focus:border-blue-500"
        />
      </div>

      <div>
        <label for="email" class="block text-sm font-medium mb-2">Email</label>
        <input
          type="email"
          id="email"
          name="email"
          required
          class="w-full px-4 py-3 bg-white dark:bg-slate-800 border border-slate-200 dark:border-slate-700 rounded-lg focus:outline-none focus:border-blue-500"
        />
      </div>

      <div>
        <label for="subject" class="block text-sm font-medium mb-2">Subject</label>
        <select
          id="subject"
          name="subject"
          class="w-full px-4 py-3 bg-white dark:bg-slate-800 border border-slate-200 dark:border-slate-700 rounded-lg focus:outline-none focus:border-blue-500"
        >
          <option value="">Select a topic...</option>
          <option value="review-request">Request a Review</option>
          <option value="general">General Question</option>
          <option value="partnership">Partnership Inquiry</option>
          <option value="other">Other</option>
        </select>
      </div>

      <div>
        <label for="message" class="block text-sm font-medium mb-2">Message</label>
        <textarea
          id="message"
          name="message"
          rows="5"
          required
          class="w-full px-4 py-3 bg-white dark:bg-slate-800 border border-slate-200 dark:border-slate-700 rounded-lg focus:outline-none focus:border-blue-500"
        ></textarea>
      </div>

      <button
        type="submit"
        class="w-full px-6 py-3 bg-blue-500 hover:bg-blue-600 text-white font-medium rounded-lg transition-colors"
      >
        Send Message
      </button>
    </form>

    <div class="mt-12 pt-8 border-t border-slate-200 dark:border-slate-800">
      <p class="text-slate-500">
        For urgent inquiries, you can also reach us at{' '}
        <a href={`mailto:${siteConfig.author.email}`} class="text-blue-500 hover:text-blue-600">
          {siteConfig.author.email}
        </a>
      </p>
    </div>
  </main>

  <Footer />
</BaseLayout>