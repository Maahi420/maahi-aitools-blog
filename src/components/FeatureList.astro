---
interface Feature {
  icon?: string;
  title: string;
  description: string;
}

interface Props {
  features: Feature[];
  columns?: 2 | 3;
}

const { features, columns = 2 } = Astro.props;
---

<div class:list={["grid gap-6 my-8", columns === 2 ? "md:grid-cols-2" : "md:grid-cols-3"]}>
  {features.map(feature => (
    <div class="flex gap-4 p-4 bg-white dark:bg-slate-800 rounded-lg border border-slate-200 dark:border-slate-700">
      {feature.icon && (
        <div class="flex-shrink-0 w-10 h-10 flex items-center justify-center bg-blue-100 dark:bg-blue-900/30 rounded-lg">
          <span class="text-xl">{feature.icon}</span>
        </div>
      )}
      <div>
        <h4 class="font-semibold mb-1">{feature.title}</h4>
        <p class="text-sm text-slate-600 dark:text-slate-400">{feature.description}</p>
      </div>
    </div>
  ))}
</div>