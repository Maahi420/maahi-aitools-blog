---
interface TableRow {
  feature: string;
  [key: string]: string;
}

interface Props {
  title?: string;
  table: TableRow[];
}

const { title = "Comparison", table } = Astro.props;

const columns = table.length > 0 ? Object.keys(table[0]).filter(k => k !== 'feature') : [];
---

<section class="py-12 lg:py-16 bg-white dark:bg-slate-900">
  <div class="mx-auto max-w-6xl px-4 sm:px-6 lg:px-8">
    <h2 class="text-2xl lg:text-3xl font-bold text-slate-900 dark:text-white mb-8 text-center">
      {title}
    </h2>

    <div class="overflow-x-auto">
      <table class="w-full min-w-[600px]">
        <thead>
          <tr class="border-b-2 border-slate-200 dark:border-slate-700">
            <th class="text-left py-4 px-4 text-sm font-bold text-slate-500 dark:text-slate-400 uppercase tracking-wider">
              Feature
            </th>
            {columns.map(col => (
              <th class="text-center py-4 px-4 text-sm font-bold text-slate-900 dark:text-white">
                {col}
              </th>
            ))}
          </tr>
        </thead>
        <tbody>
          {table.map((row, index) => (
            <tr class:list={[
              "border-b border-slate-200 dark:border-slate-700",
              index % 2 === 0 ? "bg-slate-50 dark:bg-slate-800/50" : ""
            ]}>
              <td class="py-4 px-4 font-medium text-slate-900 dark:text-white">
                {row.feature}
              </td>
              {columns.map(col => (
                <td class="text-center py-4 px-4 text-slate-700 dark:text-slate-300">
                  {row[col]}
                </td>
              ))}
            </tr>
          ))}
        </tbody>
      </table>
    </div>
  </div>
</section>