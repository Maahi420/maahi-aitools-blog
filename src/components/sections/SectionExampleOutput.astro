---
interface Props {
  title?: string;
  content: string;
}

const { title = "Real Example Output", content } = Astro.props;
---

<section class="py-10 bg-white dark:bg-slate-900">
  <div class="mx-auto max-w-4xl px-4 sm:px-6 lg:px-8">
    <h3 class="text-xl font-bold text-slate-900 dark:text-white mb-4 flex items-center gap-2">
      <svg class="w-5 h-5 text-blue-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 20l4-16m4 4l4 4-4 4M6 16l-4-4 4-4" />
      </svg>
      {title}
    </h3>

    <div class="bg-slate-900 rounded-xl p-5 overflow-x-auto">
      <pre class="text-sm text-slate-300 font-mono whitespace-pre-wrap">{content}</pre>
    </div>
  </div>
</section>