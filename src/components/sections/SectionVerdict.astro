---
interface Props {
  title?: string;
  content: string;
  cta?: string;
  ctaLink?: string;
}

const { title = "Final Verdict", content, cta, ctaLink } = Astro.props;
---

<section class="py-12 lg:py-16 bg-gradient-to-br from-blue-600 to-blue-800 text-white">
  <div class="mx-auto max-w-4xl px-4 sm:px-6 lg:px-8">
    <div class="flex items-center justify-center gap-3 mb-6">
      <svg class="w-8 h-8 text-amber-400" fill="currentColor" viewBox="0 0 20 20">
        <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 9.162c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
      </svg>
      <h2 class="text-2xl lg:text-3xl font-bold">
        {title}
      </h2>
    </div>

    <div class="prose prose-invert max-w-none mb-8">
      <p class="text-lg text-blue-100 leading-relaxed whitespace-pre-line">
        {content}
      </p>
    </div>

    {cta && (
      <div class="text-center">
        <a
          href={ctaLink || "#"}
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-2 px-8 py-4 bg-white text-blue-600 font-bold rounded-xl hover:bg-blue-50 transition-colors shadow-lg hover:shadow-xl"
        >
          {cta}
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
          </svg>
        </a>
      </div>
    )}
  </div>
</section>