---
import { siteConfig } from '../config/siteConfig';

const currentYear = new Date().getFullYear();

const footerLinks = {
  categories: [
    { href: '/category/ai-chatbots', label: 'AI Chatbots' },
    { href: '/category/ai-writing', label: 'Writing Tools' },
    { href: '/category/ai-image', label: 'Image Generators' },
    { href: '/category/ai-video', label: 'Video Tools' },
    { href: '/category/ai-coding', label: 'Coding Assistants' },
  ],
  comparisons: [
    { href: '/compare', label: 'Compare Tools' },
    { href: '/popular', label: 'Popular Tools' },
    { href: '/best-free', label: 'Best Free' },
    { href: '/best-paid', label: 'Best Paid' },
  ],
  company: [
    { href: '/about', label: 'About Us' },
    { href: '/methodology', label: 'Our Methodology' },
    { href: '/contact', label: 'Contact' },
    { href: '/privacy', label: 'Privacy Policy' },
  ],
};
---

<footer class="bg-slate-900 text-slate-300">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 py-16">
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-6 gap-10">
      <div class="lg:col-span-2">
        <a href="/" class="flex items-center gap-2 group">
          <div class="w-10 h-10 rounded-xl bg-gradient-to-br from-blue-500 to-blue-600 flex items-center justify-center shadow-lg group-hover:shadow-glow transition-shadow">
            <svg class="w-5 h-5 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-13h-7z" />
            </svg>
          </div>
          <span class="text-xl font-bold text-white group-hover:text-blue-400 transition-colors">
            {siteConfig.name}
          </span>
        </a>
        <p class="mt-4 text-sm text-slate-400 leading-relaxed">
          {siteConfig.description}
        </p>
        
        <div class="mt-6 flex items-center gap-4">
          <a href="/rss.xml" class="w-10 h-10 rounded-lg bg-slate-800 flex items-center justify-center text-slate-400 hover:text-orange-400 hover:bg-slate-700 transition-all" aria-label="RSS Feed">
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
              <path d="M6.18 15.64a2.18 2.18 0 0 1 2.18 2.18C8.36 19 7.38 20 6.18 20C5 20 4 19 4 17.82a2.18 2.18 0 0 1 2.18-2.18M4 4.44A15.56 15.56 0 0 1 19.56 20h-2.83A12.73 12.73 0 0 0 4 7.27V4.44m0 5.66a9.9 9.9 0 0 1 9.9 9.9h-2.83A7.07 7.07 0 0 0 4 12.93V10.1z"/>
            </svg>
          </a>
          <a href="https://twitter.com" class="w-10 h-10 rounded-lg bg-slate-800 flex items-center justify-center text-slate-400 hover:text-blue-400 hover:bg-slate-700 transition-all" aria-label="Twitter">
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
              <path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/>
            </svg>
          </a>
          <a href="https://github.com" class="w-10 h-10 rounded-lg bg-slate-800 flex items-center justify-center text-slate-400 hover:text-white hover:bg-slate-700 transition-all" aria-label="GitHub">
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
              <path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.846 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.575-2.79 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0 0 24 12c0-6.63-5.37-12-12-12z"/>
            </svg>
          </a>
        </div>
      </div>

      <div>
        <h3 class="text-white font-semibold mb-4">Categories</h3>
        <ul class="space-y-3">
          {footerLinks.categories.map(link => (
            <li>
              <a href={link.href} class="text-sm text-slate-400 hover:text-blue-400 transition-colors">
                {link.label}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <div>
        <h3 class="text-white font-semibold mb-4">Compare</h3>
        <ul class="space-y-3">
          {footerLinks.comparisons.map(link => (
            <li>
              <a href={link.href} class="text-sm text-slate-400 hover:text-blue-400 transition-colors">
                {link.label}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <div>
        <h3 class="text-white font-semibold mb-4">Company</h3>
        <ul class="space-y-3">
          {footerLinks.company.map(link => (
            <li>
              <a href={link.href} class="text-sm text-slate-400 hover:text-blue-400 transition-colors">
                {link.label}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <div>
        <h3 class="text-white font-semibold mb-4">Newsletter</h3>
        <p class="text-sm text-slate-400 mb-4">
          Get weekly AI insights delivered to your inbox.
        </p>
        <form class="flex flex-col gap-3">
          <input
            type="email"
            placeholder="your@email.com"
            class="w-full px-4 py-2.5 bg-slate-800 border border-slate-700 rounded-lg text-white text-sm placeholder-slate-500 focus:outline-none focus:border-blue-500 focus:ring-1 focus:ring-blue-500"
          />
          <button
            type="submit"
            class="w-full px-4 py-2.5 bg-blue-500 hover:bg-blue-600 text-white font-medium rounded-lg transition-colors text-sm"
          >
            Subscribe
          </button>
        </form>
      </div>
    </div>

    <div class="mt-12 pt-8 border-t border-slate-800">
      <div class="flex flex-col md:flex-row justify-between items-center gap-4">
        <p class="text-sm text-slate-500">
          © {currentYear} {siteConfig.name}. All rights reserved.
        </p>
        <div class="flex items-center gap-6 text-sm text-slate-500">
          <span class="flex items-center gap-2">
            <svg class="w-4 h-4 text-emerald-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
            </svg>
            Independent Reviews
          </span>
          <span class="flex items-center gap-2">
            <svg class="w-4 h-4 text-emerald-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
            </svg>
            Unbiased Opinions
          </span>
        </div>
      </div>
    </div>
  </div>
</footer>