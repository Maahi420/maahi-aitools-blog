---
interface Tool {
  name: string;
  image?: string;
  rating?: number;
  price?: string;
  bestFor?: string;
  features: string[];
  pros: string[];
  cons: string[];
  link?: string;
  cta?: string;
}

interface Props {
  title?: string;
  subtitle?: string;
  tools: Tool[];
  highlight?: number;
}

const { title = "Compare Tools", subtitle, tools = [], highlight = 0 } = Astro.props;

const featureCategories = [
  { key: 'ease', label: 'Ease of Use', icon: 'user' },
  { key: 'quality', label: 'Output Quality', icon: 'star' },
  { key: 'features', label: 'Features', icon: 'cog' },
  { key: 'value', label: 'Value', icon: 'dollar' },
  { key: 'support', label: 'Support', icon: 'support' },
];
---

<section class="py-16 bg-white dark:bg-slate-900">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <div class="text-center mb-12">
      <h2 class="text-3xl md:text-4xl font-bold text-slate-900 dark:text-white mb-4">
        {title}
      </h2>
      {subtitle && (
        <p class="text-lg text-slate-600 dark:text-slate-400 max-w-2xl mx-auto">
          {subtitle}
        </p>
      )}
    </div>

    {tools.length > 0 ? (
      <div class="overflow-x-auto">
        <table class="w-full min-w-[700px]">
          <thead>
            <tr class="border-b border-slate-200 dark:border-slate-700">
              <th class="text-left py-4 px-4 text-sm font-semibold text-slate-500 dark:text-slate-400 w-48">
                Feature
              </th>
              {tools.map((tool, index) => (
                <th class:list={[
                  'text-center py-4 px-4',
                  highlight === index ? 'bg-blue-50 dark:bg-blue-900/20' : ''
                ]}>
                  <div class="flex flex-col items-center gap-2">
                    {tool.image ? (
                      <img src={tool.image} alt={tool.name} class="w-12 h-12 rounded-lg object-contain" />
                    ) : (
                      <div class="w-12 h-12 rounded-lg bg-slate-100 dark:bg-slate-800 flex items-center justify-center">
                        <span class="text-lg font-bold text-slate-400">{tool.name.charAt(0)}</span>
                      </div>
                    )}
                    <div>
                      <span class:list={[
                        'text-lg font-bold text-slate-900 dark:text-white',
                        highlight === index ? 'text-blue-600 dark:text-blue-400' : ''
                      ]}>
                        {tool.name}
                      </span>
                      {highlight === index && (
                        <span class="block text-xs font-medium text-blue-500">Top Pick</span>
                      )}
                    </div>
                  </div>
                </th>
              ))}
            </tr>
          </thead>
          <tbody>
            <tr class="border-b border-slate-200 dark:border-slate-700">
              <td class="py-4 px-4">
                <span class="text-sm font-medium text-slate-600 dark:text-slate-400">Rating</span>
              </td>
              {tools.map((tool, index) => (
                <td class:list={['text-center py-4 px-4', highlight === index ? 'bg-blue-50 dark:bg-blue-900/20' : '']}>
                  <div class="flex items-center justify-center gap-1">
                    <svg class="w-5 h-5 text-amber-400 fill-amber-400" viewBox="0 0 20 20">
                      <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 9.162c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
                    </svg>
                    <span class="text-lg font-bold text-slate-900 dark:text-white">{tool.rating || 'N/A'}</span>
                  </div>
                </td>
              ))}
            </tr>

            <tr class="border-b border-slate-200 dark:border-slate-700">
              <td class="py-4 px-4">
                <span class="text-sm font-medium text-slate-600 dark:text-slate-400">Pricing</span>
              </td>
              {tools.map((tool, index) => (
                <td class:list={['text-center py-4 px-4', highlight === index ? 'bg-blue-50 dark:bg-blue-900/20' : '']}>
                  <span class:list={[
                    'inline-block px-3 py-1 text-sm font-medium rounded-full',
                    tool.price?.toLowerCase().includes('free') 
                      ? 'bg-emerald-100 dark:bg-emerald-900/30 text-emerald-700 dark:text-emerald-300'
                      : 'bg-slate-100 dark:bg-slate-800 text-slate-700 dark:text-slate-300'
                  ]}>
                    {tool.price || 'Check Website'}
                  </span>
                </td>
              ))}
            </tr>

            <tr class="border-b border-slate-200 dark:border-slate-700">
              <td class="py-4 px-4">
                <span class="text-sm font-medium text-slate-600 dark:text-slate-400">Best For</span>
              </td>
              {tools.map((tool, index) => (
                <td class:list={['text-center py-4 px-4', highlight === index ? 'bg-blue-50 dark:bg-blue-900/20' : '']}>
                  <span class="text-sm text-slate-700 dark:text-slate-300">
                    {tool.bestFor || 'General Use'}
                  </span>
                </td>
              ))}
            </tr>

            <tr class="border-b border-slate-200 dark:border-slate-700">
              <td class="py-4 px-4 align-top">
                <span class="text-sm font-medium text-slate-600 dark:text-slate-400">Key Features</span>
              </td>
              {tools.map((tool, index) => (
                <td class:list={['py-4 px-4', highlight === index ? 'bg-blue-50 dark:bg-blue-900/20' : '']}>
                  <ul class="text-sm text-slate-700 dark:text-slate-300 space-y-1">
                    {tool.features.slice(0, 4).map(feature => (
                      <li class="flex items-start gap-2">
                        <svg class="w-4 h-4 text-emerald-500 mt-0.5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                        </svg>
                        <span>{feature}</span>
                      </li>
                    ))}
                  </ul>
                </td>
              ))}
            </tr>

            <tr class="border-b border-slate-200 dark:border-slate-700">
              <td class="py-4 px-4 align-top">
                <span class="text-sm font-medium text-slate-600 dark:text-slate-400">Pros</span>
              </td>
              {tools.map((tool, index) => (
                <td class:list={['py-4 px-4', highlight === index ? 'bg-blue-50 dark:bg-blue-900/20' : '']}>
                  <ul class="text-sm space-y-1">
                    {tool.pros.slice(0, 3).map(pro => (
                      <li class="flex items-start gap-2">
                        <svg class="w-4 h-4 text-emerald-500 mt-0.5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                        </svg>
                        <span class="text-slate-700 dark:text-slate-300">{pro}</span>
                      </li>
                    ))}
                  </ul>
                </td>
              ))}
            </tr>

            <tr class="border-b border-slate-200 dark:border-slate-700">
              <td class="py-4 px-4 align-top">
                <span class="text-sm font-medium text-slate-600 dark:text-slate-400">Cons</span>
              </td>
              {tools.map((tool, index) => (
                <td class:list={['py-4 px-4', highlight === index ? 'bg-blue-50 dark:bg-blue-900/20' : '']}>
                  <ul class="text-sm space-y-1">
                    {tool.cons.slice(0, 2).map(con => (
                      <li class="flex items-start gap-2">
                        <svg class="w-4 h-4 text-red-500 mt-0.5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
                        </svg>
                        <span class="text-slate-600 dark:text-slate-400">{con}</span>
                      </li>
                    ))}
                  </ul>
                </td>
              ))}
            </tr>

            <tr>
              <td class="py-4 px-4"></td>
              {tools.map((tool, index) => (
                <td class:list={['text-center py-4 px-4', highlight === index ? 'bg-blue-50 dark:bg-blue-900/20' : '']}>
                  <a
                    href={tool.link || '#'}
                    class:list={[
                      'inline-flex items-center gap-2 px-4 py-2.5 rounded-lg font-medium transition-all',
                      highlight === index 
                        ? 'bg-blue-500 text-white hover:bg-blue-600 hover:shadow-lg'
                        : 'bg-slate-100 dark:bg-slate-800 text-slate-700 dark:text-slate-300 hover:bg-slate-200 dark:hover:bg-slate-700'
                    ]}
                  >
                    {tool.cta || 'View Review'}
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
                    </svg>
                  </a>
                </td>
              ))}
            </tr>
          </tbody>
        </table>
      </div>
    ) : (
      <div class="text-center py-12">
        <p class="text-slate-500 dark:text-slate-400 mb-4">
          No comparison data available yet.
        </p>
        <a href="/compare" class="inline-flex items-center gap-2 px-5 py-2.5 bg-blue-500 text-white rounded-lg font-medium hover:bg-blue-600 transition-colors">
          View All Comparisons
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
          </svg>
        </a>
      </div>
    )}
  </div>
</section>